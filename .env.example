# Smart Stadium Assistant - Environment Variables
# ------------------------------------------------------------------
# Copy this file to .env to use the Live AI mode.
# If no API key is provided, the application will gracefully degrade 
# into the deterministic Offline Engine fallback mode.
# ------------------------------------------------------------------

# Google Gemini API Key for Live AI Mode
# (Can be a standard Google AI Studio key OR an OpenRouter key starting with sk-or-)
GEMINI_API_KEY="your-gemini-api-key-here"

# The backend will automatically detect an OpenRouter key ('sk-or-...')
# and route requests to 'https://openrouter.ai/api/v1' using 'google/gemini-2.5-flash'.
